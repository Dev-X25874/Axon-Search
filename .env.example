# ── Axon Search · Environment Configuration ───────────────────────────────
# Copy this file to .env and fill in values.
# Never commit .env to source control.

# ── Index storage ──────────────────────────────────────────────────────────
INDEX_DIR=./data/index

# ── Embedding model (bi-encoder) ───────────────────────────────────────────
# Any sentence-transformers compatible model.
# Recommended open alternatives:
#   BAAI/bge-base-en-v1.5    (smaller, faster)
#   intfloat/e5-large-v2
#   thenlper/gte-large
EMBED_MODEL=BAAI/bge-large-en-v1.5
EMBED_DIM=1024
EMBED_BATCH_SIZE=64
EMBED_MAX_LENGTH=512
EMBED_DEVICE=cpu          # cpu | cuda | mps

# ── Reranker model (cross-encoder) ─────────────────────────────────────────
# Any cross-encoder/ms-marco-* model works.
# Alternatives:
#   cross-encoder/ms-marco-TinyBERT-L-2-v2  (fastest)
#   cross-encoder/ms-marco-electra-base      (best quality)
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-12-v2
RERANK_BATCH_SIZE=32
RERANK_MAX_LENGTH=512
RERANK_DEVICE=cpu

# ── Vector index ───────────────────────────────────────────────────────────
# flat   → exact search, correct, slow at scale
# hnsw   → approximate, best recall/speed < 10M vectors (default)
# ivf    → approximate, best at > 10M vectors (needs training)
VECTOR_INDEX_TYPE=hnsw
HNSW_M=32
HNSW_EF_CONSTRUCTION=200
HNSW_EF_SEARCH=64

# ── Crawler ────────────────────────────────────────────────────────────────
CRAWL_DELAY=1.0           # minimum seconds between requests to same domain
CRAWL_CONCURRENCY=32
CRAWL_MAX_DEPTH=3
CRAWL_MAX_PAGES=10000
CRAWL_REQUEST_TIMEOUT=15.0
CRAWL_MAX_RESPONSE_MB=5

# ── Quality & dedup gates ──────────────────────────────────────────────────
QUALITY_THRESHOLD=0.35    # 0.0–1.0; pages below this are dropped
MIN_WORDS=80              # hard minimum word count to index
MAX_LINK_DENSITY=0.4      # pages with higher link/word ratio are dropped
DEDUP_THRESHOLD=0.8       # Jaccard similarity threshold for near-dedup
DEDUP_NUM_PERM=128        # MinHash permutations (higher = more accurate)

# ── Retrieval ──────────────────────────────────────────────────────────────
NEURAL_FILTER_THRESHOLD=0.25   # minimum bi-encoder cosine sim to pass
BM25_WEIGHT=1.0                # RRF weight for BM25 leg
DENSE_WEIGHT=1.0               # RRF weight for dense leg
PAGERANK_ALPHA=0.1             # authority boost coefficient

# ── API server ─────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
API_RELOAD=false
LOG_LEVEL=INFO
